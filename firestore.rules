rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Default Deny Catch-all Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // =========================================================================
    // SECTION A: REUSABLE GLOBAL HELPERS & RBAC IDENTITY SYSTEM
    // =========================================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Fetch user doc securely from /users
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getRole() {
      return userExists() ? getUserDoc().role : 'Visitor';
    }

    // Enterprise Role Hierarchy Predicates
    function isSuperAdmin() {
      return isSignedIn() && (
        (userExists() && getUserDoc().role == 'Super Admin') || 
        request.auth.token.email == 'amjid.bisconni@gmail.com'
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        isSuperAdmin() || 
        (userExists() && (getUserDoc().role == 'Admin' || getUserDoc().role == 'Moderator'))
      );
    }

    function isShowroomOwner() {
      return isSignedIn() && (
        isAdmin() || 
        (userExists() && (getUserDoc().role == 'Showroom Owner' || getUserDoc().role == 'Dealer'))
      );
    }

    function isShowroomStaff() {
      return isSignedIn() && (
        isShowroomOwner() || 
        (userExists() && (getUserDoc().role == 'Showroom Staff' || getUserDoc().role == 'Sales Executive'))
      );
    }

    function isIndividualUser() {
      return isSignedIn() && (
        isShowroomStaff() || 
        (userExists() && (getUserDoc().role == 'Individual User' || getUserDoc().role == 'Private Seller' || getUserDoc().role == 'Buyer'))
      );
    }

    // =========================================================================
    // SECTION B: ENTITY DATA VALIDATION SCHEMAS
    // =========================================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'status', 'createdAt'])
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 150
        && data.role is string && data.role.size() <= 50
        && data.status is string && data.status.size() <= 50;
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['uid', 'displayName', 'createdAt'])
        && data.uid == request.auth.uid
        && data.displayName is string && data.displayName.size() >= 2 && data.displayName.size() <= 100;
    }

    function isValidShowroom(data) {
      return data.keys().hasAll(['id', 'name', 'ownerUid', 'createdAt'])
        && isValidId(data.id)
        && data.name is string && data.name.size() >= 2 && data.name.size() <= 150
        && data.ownerUid is string && data.ownerUid.size() <= 128;
    }

    function isValidVehicle(data) {
      return data.keys().hasAll(['id', 'title', 'priceRaw', 'createdBy', 'status', 'activeFlag', 'createdAt'])
        && isValidId(data.id)
        && data.title is string && data.title.size() >= 3 && data.title.size() <= 150
        && data.priceRaw is int
        && data.createdBy is string && data.createdBy.size() <= 128
        && data.status is string && data.status.size() <= 50;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'chatId', 'senderId', 'text', 'timestamp'])
        && isValidId(data.id)
        && data.chatId is string && data.chatId.size() <= 128
        && data.senderId == request.auth.uid
        && data.text is string && data.text.size() <= 5000;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['id', 'type', 'userName', 'userPhone', 'createdAt'])
        && isValidId(data.id)
        && data.userName is string && data.userName.size() >= 2 && data.userName.size() <= 100
        && data.userPhone is string && data.userPhone.size() >= 7 && data.userPhone.size() <= 20;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['id', 'targetId', 'authorName', 'rating', 'comment'])
        && isValidId(data.id)
        && data.targetId is string && data.targetId.size() <= 128
        && data.authorName is string && data.authorName.size() <= 100
        && data.rating is int && data.rating >= 1 && data.rating <= 5
        && data.comment is string && data.comment.size() <= 1000;
    }

    // =========================================================================
    // SECTION C: SPECIFIC COLLECTION PATH SECURITY MATCHERS
    // =========================================================================

    // Users collection (PII Protected)
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) 
        && (incoming().role == 'Visitor' || incoming().role == 'Buyer' || incoming().role == 'Individual User' || !incoming().keys().contains('role'));
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin()) && (
        isAdmin() || (
          incoming().role == existing().role && 
          incoming().uid == existing().uid &&
          incoming().createdAt == existing().createdAt
        )
      );
      allow delete: if isSuperAdmin();
    }

    // User Profiles
    match /profiles/{profileId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == profileId && isValidProfile(incoming());
      allow update: if isSignedIn() && (isOwner(profileId) || isAdmin()) && (
        isAdmin() || (
          incoming().uid == existing().uid &&
          incoming().createdAt == existing().createdAt
        )
      );
      allow delete: if isAdmin();
    }

    // Showrooms
    match /showrooms/{showroomId} {
      allow read: if true;
      allow create: if isShowroomOwner() && isValidShowroom(incoming()) && incoming().ownerUid == request.auth.uid;
      allow update: if isSignedIn() && (isAdmin() || (existing().ownerUid == request.auth.uid && incoming().ownerUid == existing().ownerUid)) && (
        isAdmin() || incoming().id == existing().id
      );
      allow delete: if isAdmin();
    }

    // Showroom Staff
    match /showroomStaff/{staffId} {
      allow read: if isSignedIn();
      allow write: if isShowroomOwner();
    }

    // Vehicles
    match /vehicles/{vehicleId} {
      allow read: if true;
      allow create: if isIndividualUser() && isValidVehicle(incoming()) && incoming().createdBy == request.auth.uid && incoming().createdAt == request.time;
      allow update: if isSignedIn() && (isAdmin() || existing().createdBy == request.auth.uid) && (
        isAdmin() || (
          incoming().createdBy == existing().createdBy &&
          incoming().createdAt == existing().createdAt &&
          incoming().id == existing().id
        )
      );
      allow delete: if isSignedIn() && (isAdmin() || existing().createdBy == request.auth.uid);
    }

    // Vehicle Images Metadata
    match /vehicleImages/{imageId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Vehicle Videos Metadata
    match /vehicleVideos/{videoId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Favorites
    match /favorites/{favoriteId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Messages
    match /messages/{messageId} {
      allow get, list: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid || isShowroomStaff());
      allow create: if isSignedIn() && isValidMessage(incoming());
      allow update: if isSignedIn() && (existing().senderId == request.auth.uid || existing().receiverId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Chats thread record
    match /chats/{chatId} {
      allow read: if isSignedIn() && (resource.data.participantIds.hasAny([request.auth.uid]) || isShowroomStaff());
      allow write: if isSignedIn();
    }

    // Notifications (owned read only)
    match /notifications/{notificationId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin() || (isSignedIn() && incoming().userId == request.auth.uid);
      allow update: if isSignedIn() && existing().userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Saved Search histories
    match /searchHistory/{searchId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Recent view lists
    match /recentViews/{viewId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Showroom Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidReview(incoming());
      allow update: if isSignedIn() && (isAdmin() || (existing().authorId == request.auth.uid));
      allow delete: if isSignedIn() && (isAdmin() || (existing().authorId == request.auth.uid));
    }

    // Showroom Ratings
    match /ratings/{ratingId} {
      allow read: if true;
      allow write: if isSignedIn() || isAdmin();
    }

    // Customer Leads CRM
    match /leads/{leadId} {
      allow read: if isShowroomStaff();
      allow create: if true; // Anyone can submit inquiries
      allow update, delete: if isShowroomStaff();
    }

    // Visitor clickstream tracking
    match /visitors/{visitorId} {
      allow read: if isAdmin();
      allow write: if true; // Client telemetry tracking
    }

    // Customer support desk tickets
    match /supportTickets/{ticketId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // Ad postings transaction ledger
    match /payments/{paymentId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isShowroomOwner();
      allow update, delete: if isSuperAdmin();
    }

    // Dealer premium tier registrations
    match /subscriptions/{subscriptionId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Targeted marketing campaigns
    match /advertisements/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Aggregated Business Intelligence Tracker
    match /analytics/{analyticsId} {
      allow read: if isAdmin();
      allow write: if true; // Allows anonymous frontend event logging
    }

    // Core dynamic app constants
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Transactional user activity security ledger
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isSignedIn();
    }

    // Custom programmatic metadata injections (SEO)
    match /seo/{seoId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Critical client/server runtime diagnostics
    match /systemLogs/{logId} {
      allow read: if isAdmin();
      allow write: if true; // Allow logging runtime issues even before authentication
    }

    // Activity Logs
    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isSignedIn();
    }

    // Inventory items catalog
    match /inventory/{itemId} {
      allow read: if true;
      allow create: if isShowroomOwner();
      allow update: if isShowroomOwner() && existing().showroomId == incoming().showroomId;
      allow delete: if isShowroomOwner();
    }

    // Global Seeding Sentinels
    match /system/{docId} {
      allow read: if true;
      allow write: if isSignedIn() || isSuperAdmin();
    }

    // Backward compatibility matchers
    match /dealers/{dealerId} {
      allow read: if true;
      allow write: if isShowroomOwner() || isAdmin();
      match /reviews/{reviewId} { allow read: if true; allow write: if isSignedIn(); }
    }
    match /listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isAdmin() || resource.data.dealerId == request.auth.uid || resource.data.createdBy == request.auth.uid || resource.data.ownerId == request.auth.uid);
    }
  }
}
