{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with role-based access control and verification attributes for the long term",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user authentication ID matching Firebase Auth" },
        "email": { "type": "string", "description": "User's verified email address" },
        "displayName": { "type": "string", "description": "User display pre-formatted moniker" },
        "phoneNumber": { "type": "string", "description": "User verified contact number" },
        "city": { "type": "string", "description": "Geographical city address" },
        "state": { "type": "string", "description": "Geographical state address" },
        "role": { "type": "string", "enum": ["Admin", "Showroom Owner", "Sales Rep", "Private Seller", "Buyer"], "description": "RBAC privilege tier" },
        "status": { "type": "string", "enum": ["Active", "Pending Approval", "Suspended"], "description": "Operational user status" },
        "socials": { "type": "object", "description": "Social media links for showrooms and sellers" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "status", "createdAt", "lastLogin"]
    },
    "Dealer": {
      "title": "Verified Dealer",
      "description": "Showroom showroom identity records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "subtitle": { "type": "string" },
        "location": { "type": "string" },
        "rating": { "type": "number" },
        "vehiclesCount": { "type": "integer" },
        "followersCount": { "type": "string" },
        "coverImage": { "type": "string" },
        "description": { "type": "string" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "location", "rating"]
    },
    "CarListing": {
      "title": "Vehicle Listing",
      "description": "Car listing with technical parameters, prices, and assigned managers or sales reps",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "make": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "integer" },
        "price": { "type": "integer" },
        "mileage": { "type": "integer" },
        "fuelType": { "type": "string", "enum": ["Petrol", "Diesel", "Hybrid", "Electric"] },
        "transmission": { "type": "string", "enum": ["Automatic", "Manual"] },
        "imageUrl": { "type": "string" },
        "verified": { "type": "boolean" },
        "featured": { "type": "boolean" },
        "approved": { "type": "boolean", "description": "Moderator approval flag" },
        "dealerId": { "type": "string" },
        "assignedSalesRepId": { "type": "string" },
        "region": { "type": "string" },
        "salesPodId": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "make", "model", "year", "price", "dealerId", "assignedSalesRepId", "region", "createdAt", "updatedAt"]
    },
    "Review": {
      "title": "Verified Review",
      "description": "Verified client response feedback and ratings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "author": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "author", "rating", "comment", "createdAt"]
    },
    "Offer": {
      "title": "Dynamic Offer",
      "description": "Non-binding customer bid or pricing proposal across the pipeline",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "listingId": { "type": "string" },
        "buyerId": { "type": "string" },
        "buyerName": { "type": "string" },
        "price": { "type": "integer" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "listingId", "buyerId", "price", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User metadata and multi-role RBAC attributes"
    },
    "/dealers/{dealerId}": {
      "schema": "Dealer",
      "description": "Automotive showrooms profiles"
    },
    "/listings/{listingId}": {
      "schema": "CarListing",
      "description": "Marketplace vehicle entries"
    },
    "/dealers/{dealerId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Showroom buyer feedback"
    },
    "/listings/{listingId}/offers/{offerId}": {
      "schema": "Offer",
      "description": "Proposals on specific cars"
    }
  }
}
