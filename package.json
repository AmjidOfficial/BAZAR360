{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://bazar360.online",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "cross-env GH_PAGES=true vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:gh-pages": "cross-env GH_PAGES=true vite build",
    "predeploy": "npm run build:gh-pages",
    "deploy": "gh-pages -d dist",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
